"c": "res://chat/character/c.dch",
"j": "res://chat/character/j.dch",
"jl": "res://chat/character/jl.dch",
"k": "res://chat/character/k.dch",
"kkl": "res://chat/character/kkl.dch",
"kl": "res://chat/character/kl.dch",
"ln": "res://chat/character/ln.dch",
"pklm": "res://chat/character/pklm.dch",
